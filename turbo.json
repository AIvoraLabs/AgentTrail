{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "tsconfig.json"
  ],
  "pipeline": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "test": {
      "dependsOn": [
        "build"
      ],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "docs:build": {
      "outputs": ["apps/docs/.vitepress/dist/**"]
    },
    "lint": {
      "outputs": []
    },
    "test:coverage": {
      "dependsOn": [
        "build"
      ],
      "outputs": [
        "coverage/**"
      ]
    }
  }
}
