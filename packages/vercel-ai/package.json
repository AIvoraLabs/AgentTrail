{
  "name": "@aivoralabs/agenttrail-vercel",
  "version": "0.1.0",
  "description": "Vercel AI SDK middleware for AgentTrail audit receipts",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aivoralabs/agenttrail": "workspace:*",
    "ai": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": "https://agenttrail.aivoralabs.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AiVoraLabs/agenttrail.git"
  },
  "author": "AivoraLabs <hello@aivoralabs.org>",
  "keywords": [
    "ai-compliance",
    "eu-ai-act",
    "audit-trail",
    "ai-agents",
    "article-12",
    "hash-chain",
    "cryptographic-receipts",
    "compliance",
    "ai-governance",
    "audit",
    "llm",
    "vercel-ai-sdk",
    "ai-sdk",
    "streaming",
    "middleware"
  ]
}
