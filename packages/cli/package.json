{
  "name": "@aivoralabs/agenttrail-cli",
  "version": "0.1.0",
  "description": "CLI for AgentTrail audit receipt verification",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "audit-receipt": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsup src/index.ts --format esm --watch",
    "clean": "rm -rf dist",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aivoralabs/agenttrail": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": "https://agenttrail.aivoralabs.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AiVoraLabs/agenttrail.git"
  },
  "author": "AivoraLabs <hello@aivoralabs.org>",
  "keywords": [
    "ai-compliance",
    "eu-ai-act",
    "audit-trail",
    "ai-agents",
    "article-12",
    "hash-chain",
    "cryptographic-receipts",
    "compliance",
    "ai-governance",
    "audit",
    "llm",
    "cli",
    "command-line",
    "audit-tool",
    "html-report",
    "verification"
  ]
}
