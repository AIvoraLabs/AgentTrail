{
  "name": "@aivoralabs/agenttrail",
  "version": "0.1.1",
  "description": "Compliance receipts for AI agents — EU AI Act Article 12 audit trails",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist",
    "test:coverage": "vitest run --coverage",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@noble/ed25519": "^2.2.0",
    "uuid": "^11.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "@fast-check/vitest": "^0.2.0",
    "@types/node": "^22.0.0",
    "async-mutex": "^0.5.0",
    "proper-lockfile": "^4.1.0",
    "openai": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": "https://agenttrail.aivoralabs.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AiVoraLabs/agenttrail.git"
  },
  "author": "AivoraLabs <hello@aivoralabs.org>",
  "keywords": [
    "ai-compliance",
    "eu-ai-act",
    "audit-trail",
    "ai-agents",
    "article-12",
    "hash-chain",
    "cryptographic-receipts",
    "compliance",
    "ai-governance",
    "audit",
    "llm",
    "openai"
  ]
}
