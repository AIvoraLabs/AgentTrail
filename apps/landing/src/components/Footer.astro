---
const year = new Date().getFullYear();
---

<footer class="py-12 px-6 border-t border-slate-200 dark:border-slate-800">
  <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
    <div class="text-center md:text-left">
      <p class="font-heading font-bold text-sm">AgentTrail</p>
      <p class="text-xs text-slate-500 mt-1">AI made decisions. We keep the receipts.</p>
    </div>
    <div class="flex items-center gap-6 text-xs text-slate-500">
      <span>Open-source MIT</span>
      <span>EU AI Act compliant</span>
      <span>© {year} AivoraLabs</span>
    </div>
  </div>
</footer>
