---
---

<button
  id="themeToggle"
  class="fixed top-4 right-4 z-50 p-2.5 rounded-full bg-white/10 dark:bg-black/20 backdrop-blur-sm border border-slate-200/20 hover:border-brand-500/50 transition-all duration-200 cursor-pointer"
  aria-label="Toggle theme"
>
  <!-- Sun icon (visible in dark mode — click to switch to light) -->
  <svg
    class="sun-icon block dark:hidden w-5 h-5 text-amber-400"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <circle cx="12" cy="12" r="5" />
    <line x1="12" y1="1" x2="12" y2="3" />
    <line x1="12" y1="21" x2="12" y2="23" />
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
    <line x1="1" y1="12" x2="3" y2="12" />
    <line x1="21" y1="12" x2="23" y2="12" />
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
  </svg>
  <!-- Moon icon (visible in light mode — click to switch to dark) -->
  <svg
    class="moon-icon hidden dark:block w-5 h-5 text-slate-300"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script>
  document.getElementById('themeToggle')?.addEventListener('click', function () {
    var html = document.documentElement;
    var next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });
</script>
