---
import '../styles/globals.css';

export interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark" class="overflow-x-hidden">
  <head>
    <!-- pages.dev → production domain redirect -->
    <script is:inline>
      if (window.location.hostname === 'agenttrail.pages.dev') {
        window.location.replace('https://agenttrail.aivoralabs.org' + window.location.pathname + window.location.search);
      }
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://agenttrail.aivoralabs.org" />
    <meta property="og:image" content="https://agenttrail.aivoralabs.org/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="628" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content="AgentTrail — Cryptographic audit trails for AI agents" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="AgentTrail — EU AI Act audit trails for AI agents | Open-source SDK" />
    <meta name="twitter:description" content="Cryptographic audit trails for AI agents. EU AI Act Article 12 compliance. Open-source SDK with SHA-256 hash chain and Ed25519 signatures. Zero data retention." />
    <meta name="twitter:image" content="https://agenttrail.aivoralabs.org/og-image.png" />

    <!-- Canonical URL -->
    <link rel="canonical" href="https://agenttrail.aivoralabs.org/" />
    <meta name="canonical" content="https://agenttrail.aivoralabs.org" />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="en" href="https://agenttrail.aivoralabs.org/" />
    <link rel="alternate" hreflang="x-default" href="https://agenttrail.aivoralabs.org/" />

    <!-- Theme color -->
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#EEF0E9" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#07090F" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,800&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "AgentTrail",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "description": "Open-source SDK, MIT license"
      },
      "description": "Cryptographic audit trails for AI agents. EU AI Act Article 12 compliance.",
      "url": "https://agenttrail.aivoralabs.org",
      "license": "https://opensource.org/licenses/MIT",
      "author": {
        "@type": "Organization",
        "name": "AivoraLabs"
      }
    })} />

    <!-- Organization JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "AivoraLabs",
      "url": "https://agenttrail.aivoralabs.org",
      "logo": "https://agenttrail.aivoralabs.org/og-image.png",
      "sameAs": [
        "https://github.com/AIvoraLabs/agenttrail",
        "https://www.npmjs.com/package/@aivoralabs/agenttrail"
      ]
    })} />

    <!-- FAQPage JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is EU AI Act Article 12?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Article 12 of the EU AI Act requires that high-risk AI systems automatically log every interaction with tamper-proof records, including timestamps, inputs, outputs, and the identity of any human oversight. AgentTrail implements this requirement with cryptographic audit receipts."
          }
        },
        {
          "@type": "Question",
          "name": "How does AgentTrail generate tamper-proof audit trails?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "AgentTrail uses a SHA-256 hash chain and Ed25519 digital signatures. Each receipt includes the hash of the previous receipt, making any modification detectable. An auditor can verify the entire chain offline using the CLI tool."
          }
        },
        {
          "@type": "Question",
          "name": "Is AgentTrail open source?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. AgentTrail is fully open source under the MIT license. The core SDK, OpenAI wrapper, Vercel AI middleware, and CLI tool are all available on GitHub at https://github.com/AIvoraLabs/agenttrail."
          }
        },
        {
          "@type": "Question",
          "name": "Does AgentTrail store my data?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. AgentTrail is a local-first SDK. Audit receipts are stored in your own infrastructure — local filesystem, S3, or GCS. AgentTrail never sees or stores your data."
          }
        }
      ]
    })} />

    <!-- Theme FOUC prevention -->
    <script is:inline>
      (function () {
        var theme = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (theme === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        } else if (theme === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
        }
      })();
    </script>
  </head>
  <body class="bg-surface-light dark:bg-surface-dark text-slate-900 dark:text-slate-100 font-sans antialiased transition-colors duration-300 overflow-x-hidden">
    <main id="main-content" class="max-w-full overflow-x-hidden">
      <slot />
    </main>
  </body>
</html>
